@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<h1>Lista de Characters</h1>

@if (Model.Characters?.Count > 0){
    <div style="display: flex; flex-wrap: wrap;">
        @foreach (var character in Model.Characters){
            <div style="border: 1px solid #ccc; margin: 10px; padding: 10px; width: 200px;">
                <img src="@character.ImageURL" alt="Bandeira de @character.Fighter" width="100" />
                <p><strong>@character.Fighter</strong></p>
                <p>Código: @character.Id</p>
                <a asp-page="/Infopais" asp-route-cod="@character.Id">Ver Info</a>
            </div>
        }
    </div>
}
else{
    <p>ERRO : não temos lista </p>
}